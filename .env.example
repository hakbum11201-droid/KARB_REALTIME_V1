# ============================================================
# KARB_REALTIME_V1 - 환경변수 템플릿
# ============================================================
# 이 파일을 복사하여 .env 파일로 저장하고 실제 키를 입력하세요.
# 실제 .env 파일은 절대 Git에 커밋하지 마십시오.
#
# 복사 방법:
#   copy .env.example .env     (Windows)
#   cp .env.example .env       (Linux/macOS)
# ============================================================

# Upbit API (tiny_live / live 모드에서만 필요)
UPBIT_ACCESS_KEY=YOUR_UPBIT_ACCESS_KEY_HERE
UPBIT_SECRET_KEY=YOUR_UPBIT_SECRET_KEY_HERE

# Binance API (tiny_live / live 모드에서만 필요)
BINANCE_API_KEY=YOUR_BINANCE_API_KEY_HERE
BINANCE_API_SECRET=YOUR_BINANCE_API_SECRET_HERE

# FX API (선택사항: 외부 환율 API 사용 시)
# FX_API_KEY=YOUR_FX_API_KEY_HERE
